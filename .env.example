SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_app_client_id
SHOPIFY_CLIENT_SECRET=your_app_client_secret
SHOPIFY_API_VERSION=2026-04

# Optional: set this instead of SHOPIFY_CLIENT_ID and SHOPIFY_CLIENT_SECRET
# if you already have an Admin API access token.
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_api_access_token
